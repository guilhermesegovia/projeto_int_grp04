    "nome": "Maria Silva",
    "setor": "Vendas",
    "cargo": "Gerente de Vendas",
    "data_nascimento": "1995-05-10",
    "cpf": "98765432100",
    "email": "maria.silva@example.com",
    "senha": "senha456"
}

